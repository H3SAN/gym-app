generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CUSTOMER
  ADMIN
  TRAINER
}

enum MembershipTier {
  BASIC
  PRO
  ELITE
}

enum Difficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  ATTENDED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  DELIVERED
}

enum CheckInStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CheckInMethod {
  QR
  FACE
}

enum WeightUnit {
  KG
  LBS
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  name          String
  phone         String?
  avatarUrl     String?
  role          Role     @default(CUSTOMER)
  deviceIds     String[]
  faceEmbedding Float[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships          Membership[]
  bookings             Booking[]
  cartItems            CartItem[]
  orders               Order[]
  workoutLogs          WorkoutLog[]
  checkIns             CheckInLog[]
  qrTokens             QRToken[]
  goals                Goal[]
  referralsMade        Referral[]          @relation("ReferralsMade")
  referralsReceived    Referral[]          @relation("ReferralsReceived")
  passwordResetTokens  PasswordResetToken[]
  pushSubscriptions    PushSubscription[]
  trainerSessions      TrainerSession[]
  enrolledPlans        UserWorkoutPlan[]
}

model Membership {
  id         String         @id @default(cuid())
  userId     String
  tier       MembershipTier @default(BASIC)
  startDate  DateTime       @default(now())
  endDate    DateTime
  isActive   Boolean        @default(true)
  autoRenew  Boolean        @default(true)

  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Class {
  id              String     @id @default(cuid())
  name            String
  description     String
  instructorName  String
  instructorPhoto String?
  startTime       DateTime
  endTime         DateTime
  capacity        Int        @default(20)
  bookedCount     Int        @default(0)
  difficulty      Difficulty @default(BEGINNER)
  isPro           Boolean    @default(false)
  isCancelled     Boolean    @default(false)
  location        String     @default("Main Studio")
  createdAt       DateTime   @default(now())

  bookings        Booking[]
}

model Booking {
  id        String        @id @default(cuid())
  userId    String
  classId   String
  bookedAt  DateTime      @default(now())
  status    BookingStatus @default(CONFIRMED)

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  class     Class         @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([userId, classId])
}

model Product {
  id          String      @id @default(cuid())
  name        String
  description String
  price       Float
  imageUrl    String?
  category    String
  stock       Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())

  cartItems   CartItem[]
  orderItems  OrderItem[]
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  productId String
  quantity  Int      @default(1)
  addedAt   DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}

model Order {
  id              String      @id @default(cuid())
  userId          String
  total           Float
  status          OrderStatus @default(PENDING)
  paymentIntentId String?     @unique
  shippingName    String?
  shippingLine1   String?
  shippingCity    String?
  shippingState   String?
  shippingPostal  String?
  shippingCountry String?
  createdAt       DateTime    @default(now())

  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  quantity  Int
  price     Float

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model WorkoutLog {
  id        String            @id @default(cuid())
  userId    String
  date      DateTime          @default(now())
  notes     String?
  createdAt DateTime          @default(now())

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
}

model WorkoutExercise {
  id           String     @id @default(cuid())
  workoutLogId String
  name         String
  sets         Int
  reps         Int
  weight       Float      @default(0)
  unit         WeightUnit @default(KG)

  workoutLog   WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
}

model CheckInLog {
  id          String        @id @default(cuid())
  userId      String
  checkedInAt DateTime      @default(now())
  deviceId    String?
  qrToken     String
  isValid     Boolean       @default(true)
  method      CheckInMethod @default(QR)
  status      CheckInStatus @default(APPROVED)
  reviewedAt  DateTime?
  reviewedBy  String?

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model QRToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id           String   @id @default(cuid())
  userId       String
  title        String
  targetValue  Float
  currentValue Float    @default(0)
  unit         String
  targetDate   DateTime
  createdAt    DateTime @default(now())

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Referral {
  id          String         @id @default(cuid())
  referrerId  String
  referredId  String?
  code        String         @unique
  status      ReferralStatus @default(PENDING)
  rewardGiven Boolean        @default(false)
  createdAt   DateTime       @default(now())
  completedAt DateTime?

  referrer    User           @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referred    User?          @relation("ReferralsReceived", fields: [referredId], references: [id], onDelete: SetNull)
}

enum ReferralStatus {
  PENDING
  COMPLETED
  EXPIRED
}

// ─── Feature 1: Password Reset ───────────────────────────────────────────────

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Feature 3: Push Notifications ───────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Feature 5: Trainers & Sessions ──────────────────────────────────────────

enum SessionType {
  STANDARD
  EXPRESS
}

enum SessionStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Trainer {
  id           String           @id @default(cuid())
  name         String
  bio          String
  photoUrl     String?
  specialties  String[]
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())

  sessions     TrainerSession[]
  workoutPlans WorkoutPlan[]
}

model TrainerSession {
  id          String        @id @default(cuid())
  trainerId   String
  userId      String
  scheduledAt DateTime
  duration    Int           @default(60)
  type        SessionType   @default(STANDARD)
  status      SessionStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())

  trainer     Trainer       @relation(fields: [trainerId], references: [id])
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Feature 4: Workout Plans ─────────────────────────────────────────────────

enum PlanDifficulty {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

model WorkoutPlan {
  id            String            @id @default(cuid())
  trainerId     String
  title         String
  description   String
  difficulty    PlanDifficulty    @default(BEGINNER)
  durationWeeks Int               @default(4)
  isPublished   Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  trainer       Trainer           @relation(fields: [trainerId], references: [id])
  weeks         WorkoutPlanWeek[]
  enrollments   UserWorkoutPlan[]
}

model WorkoutPlanWeek {
  id         String           @id @default(cuid())
  planId     String
  weekNumber Int

  plan       WorkoutPlan      @relation(fields: [planId], references: [id], onDelete: Cascade)
  days       WorkoutPlanDay[]
}

model WorkoutPlanDay {
  id        String                @id @default(cuid())
  weekId    String
  dayNumber Int
  label     String?
  isRest    Boolean               @default(false)

  week      WorkoutPlanWeek       @relation(fields: [weekId], references: [id], onDelete: Cascade)
  exercises WorkoutPlanExercise[]
}

model WorkoutPlanExercise {
  id          String         @id @default(cuid())
  dayId       String
  name        String
  sets        Int
  reps        Int
  restSeconds Int            @default(60)
  notes       String?
  order       Int            @default(0)

  day         WorkoutPlanDay @relation(fields: [dayId], references: [id], onDelete: Cascade)
}

model UserWorkoutPlan {
  id        String      @id @default(cuid())
  userId    String
  planId    String
  startedAt DateTime    @default(now())
  isActive  Boolean     @default(true)

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan      WorkoutPlan @relation(fields: [planId], references: [id])

  @@unique([userId, planId])
}
